{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Praktikum",
  "version": "1.0.0",
  "identifier": "ru.praktikum.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Практикум — локальные курсы",
        "width": 1240,
        "height": 840,
        "minWidth": 820,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Russian", "English"],
        "installMode": "currentUser"
      }
    }
  }
}
